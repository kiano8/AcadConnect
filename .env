# ── EMAIL ──────────────────────────────────────────────────────────
# Using Gmail SMTP.
# SMTP_USER  = your full Gmail address  e.g.  you@gmail.com
# SMTP_PASS  = your Gmail App Password  (NOT your regular password)
#
# How to get a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. App = "Mail", Device = "Windows Computer" → Generate
#   4. Copy the 16-character code and paste it below (no spaces)
# ──────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kianberong2005@gmail.com
